{
    "name": "sridhar-s-subramanian/filament-dbview",
    "description": "Adminer-like, strictly read-only database viewer for Filament panels, scoped to the host app's Eloquent models.",
    "keywords": [
        "filament",
        "laravel",
        "database",
        "adminer",
        "dbview",
        "read-only",
        "sql"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "R Sivasubramanian",
            "email": "subramaniansridhar95@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "greenlion/php-sql-parser": "^4.7",
        "illuminate/contracts": "^11.0 || ^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "SridharSSubramanian\\FilamentDbview\\": "src/",
            "SridharSSubramanian\\FilamentDbview\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SridharSSubramanian\\FilamentDbview\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/phpcs"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SridharSSubramanian\\FilamentDbview\\FilamentDbviewServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
